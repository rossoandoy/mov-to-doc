{
  "name": "operation-manual-build",
  "private": true,
  "type": "module",
  "scripts": {
    "diagram": "mmdc -i diagrams/process_flow.mmd -o images/process_flow.png -w 1400 -b white",
    "html": "node build-html.mjs",
    "pdf": "node build-pdf.mjs",
    "site": "node prepare-site.mjs",
    "build:web": "npm run diagram && npm run html && npm run site",
    "build": "npm run diagram && npm run pdf"
  },
  "devDependencies": {
    "@mermaid-js/mermaid-cli": "^11.4.0",
    "marked": "^15.0.7",
    "puppeteer-core": "^24.4.0"
  }
}
